# maldet RPM install verification — Rocky 9
# Generated by pkg_gen.sh from pkg_lib templates
#
FROM rockylinux:9

# Install dependencies that maldet requires at runtime
RUN dnf install -y --allowerasing bash grep gawk coreutils findutils file procps-ng && \
    dnf clean all

# Copy RPM and test script from build context
COPY maldet-*el9*.rpm /tmp/
COPY test-pkg-install.sh /test/test-pkg-install.sh

# Install the package
RUN rpm -ivh /tmp/maldet-*el9*.rpm

CMD ["/test/test-pkg-install.sh", "rpm"]
