# maldet RPM build environment — CentOS 7 (el7)
# Generated by pkg_gen.sh from pkg_lib templates
#
# Placeholders:
#   maldet    — package name
#   /usr/local/sbin/maldet --version 2>/dev/null | head -1 — shell command to extract version from source tree
#
FROM centos:7

# CentOS 7 is EOL — use vault mirrors
RUN sed -i 's|^mirrorlist=|#mirrorlist=|g' /etc/yum.repos.d/CentOS-*.repo && \
    sed -i 's|^#baseurl=http://mirror.centos.org|baseurl=http://vault.centos.org|g' /etc/yum.repos.d/CentOS-*.repo

RUN yum install -y rpm-build tar gzip make && \
    yum clean all

# Copy project source
COPY . /src/maldet

WORKDIR /src/maldet/pkg

# Build tarball and RPM
RUN make source && \
    mkdir -p /root/rpmbuild/{SOURCES,SPECS,BUILD,RPMS,SRPMS} && \
    cp build/maldet-*.tar.gz /root/rpmbuild/SOURCES/ && \
    cp rpm/maldet.spec /root/rpmbuild/SPECS/ && \
    rpmbuild -bb --define "dist .el7" /root/rpmbuild/SPECS/maldet.spec

CMD cp /root/rpmbuild/RPMS/noarch/*.rpm /output/
