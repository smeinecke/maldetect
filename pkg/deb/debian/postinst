#!/bin/bash
# maldet postinst — generated by pkg_gen.sh from pkg_lib templates
#
# Post-install scriptlet: sets permissions, runs config migration if
# upgrading from install.sh-based installation.
#
# Placeholders:
#   maldet            — package name
#   /usr/local/maldetect    — legacy install path
#
#
set -e

LEGACY_PATH="/usr/local/maldetect"

case "$1" in
    configure)
        chmod 750 /var/lib/maldet/sigs /var/lib/maldet/quarantine \
            /var/lib/maldet/sess /var/lib/maldet/tmp /var/lib/maldet/pub \
            /var/lib/maldet/clean /var/log/maldet 2>/dev/null || true
        chmod 640 /etc/maldet/conf.maldet /etc/maldet/ignore_paths \
            /etc/maldet/ignore_file_ext /etc/maldet/ignore_sigs \
            /etc/maldet/ignore_inotify /etc/maldet/monitor_paths \
            /etc/maldet/monitor_paths.extra 2>/dev/null || true
        # importconf: config merge from tarball backup (first install only)
        if [ -z "$2" ] && [ -d "${LEGACY_PATH}.bk.last" ]; then
            if [ -x /usr/lib/maldet/importconf ]; then
                INSTALL_PATH="$LEGACY_PATH" /usr/lib/maldet/importconf || true
            fi
        fi
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload 2>/dev/null || true
        fi
        # Post-install actions: sig migration, sigup, ClamAV linking
        if [ -x /usr/lib/maldet/internals/pkg-postinst.sh ]; then
            if [ -z "$2" ] && [ -d "${LEGACY_PATH}.bk.last" ]; then
                /usr/lib/maldet/internals/pkg-postinst.sh migrate || true
            elif [ -z "$2" ]; then
                /usr/lib/maldet/internals/pkg-postinst.sh fresh || true
            else
                /usr/lib/maldet/internals/pkg-postinst.sh upgrade || true
            fi
        fi
        ;;
esac

#DEBHELPER#

exit 0
