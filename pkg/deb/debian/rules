#!/usr/bin/make -f
# maldet Debian rules — generated by pkg_gen.sh from pkg_lib templates
#
#
%:
	dh $@

override_dh_auto_build:
	# FHS path transforms — work on .pkg copies, keep originals clean
	cp files/internals/internals.conf files/internals/internals.conf.pkg
	sed -i \
	    -e 's|^inspath=.*|inspath=/usr/lib/maldet|' \
	    -e 's|^libpath=.*|libpath="/usr/lib/maldet/internals"|' \
	    -e 's|^logdir=.*|logdir="/var/log/maldet"|' \
	    -e 's|^confpath=.*|confpath="/etc/maldet"|' \
	    -e 's|^varlibpath=.*|varlibpath="/var/lib/maldet"|' \
	    files/internals/internals.conf.pkg
	# $$ escaping: Makefile passes $$ as literal $ to shell
	cp files/internals/tlog files/internals/tlog.pkg
	sed -i 's|BASERUN="$${BASERUN:-/tmp}"|BASERUN="$${BASERUN:-/var/lib/maldet/tmp}"|' \
	    files/internals/tlog.pkg
	cp files/service/maldet.service files/service/maldet.service.pkg
	sed -i 's|/usr/local/maldetect/maldet|/usr/sbin/maldet|g' \
	    files/service/maldet.service.pkg
	cp files/service/maldet.sysconfig files/service/maldet.sysconfig.pkg
	sed -i 's|/usr/local/maldetect/monitor_paths|/etc/maldet/monitor_paths|g' \
	    files/service/maldet.sysconfig.pkg
	cp cron.daily cron.daily.pkg
	sed -i "s|inspath='/usr/local/maldetect'|inspath='/usr/lib/maldet'|" \
	    cron.daily.pkg
	cp cron.d.sigup cron.d.sigup.pkg
	sed -i 's|/usr/local/maldetect/maldet|/usr/sbin/maldet|g' \
	    cron.d.sigup.pkg
	cp cron.d.pub cron.d.pub.pkg
	sed -i 's|/usr/local/maldetect/maldet|/usr/sbin/maldet|g' \
	    cron.d.pub.pkg
	cp cron.watchdog cron.watchdog.pkg
	sed -i "s|inspath='/usr/local/maldetect'|inspath='/usr/lib/maldet'|" \
	    cron.watchdog.pkg
	cp files/maldet.1 files/maldet.1.pkg
	gzip -9 files/maldet.1.pkg

override_dh_auto_install:
	mkdir -p $(CURDIR)/debian/maldet/usr/sbin
	mkdir -p $(CURDIR)/debian/maldet/usr/lib/maldet/internals/alert/custom.d
	mkdir -p $(CURDIR)/debian/maldet/usr/lib/maldet/cron
	mkdir -p $(CURDIR)/debian/maldet/etc/maldet
	mkdir -p $(CURDIR)/debian/maldet/var/lib/maldet/sigs/custom.yara.d
	mkdir -p $(CURDIR)/debian/maldet/var/lib/maldet/quarantine
	mkdir -p $(CURDIR)/debian/maldet/var/lib/maldet/sess
	mkdir -p $(CURDIR)/debian/maldet/var/lib/maldet/tmp
	mkdir -p $(CURDIR)/debian/maldet/var/lib/maldet/pub
	mkdir -p $(CURDIR)/debian/maldet/var/lib/maldet/clean
	mkdir -p $(CURDIR)/debian/maldet/var/log/maldet
	mkdir -p $(CURDIR)/debian/maldet/usr/share/man/man1
	mkdir -p $(CURDIR)/debian/maldet/usr/share/doc/maldet
	install -m 755 files/maldet $(CURDIR)/debian/maldet/usr/sbin/maldet
	install -m 755 files/hookscan.sh $(CURDIR)/debian/maldet/usr/lib/maldet/hookscan.sh
	install -m 755 files/internals/importconf $(CURDIR)/debian/maldet/usr/lib/maldet/importconf
	install -m 755 files/modsec.sh $(CURDIR)/debian/maldet/usr/lib/maldet/modsec.sh
	install -m 640 files/internals/internals.conf.pkg $(CURDIR)/debian/maldet/usr/lib/maldet/internals/internals.conf
	install -m 750 files/internals/lmd.lib.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd.lib.sh
	install -m 750 files/internals/lmd_config.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_config.sh
	install -m 750 files/internals/lmd_init.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_init.sh
	install -m 750 files/internals/lmd_clamav.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_clamav.sh
	install -m 750 files/internals/lmd_sigs.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_sigs.sh
	install -m 750 files/internals/lmd_engine.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_engine.sh
	install -m 750 files/internals/lmd_yara.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_yara.sh
	install -m 750 files/internals/lmd_quarantine.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_quarantine.sh
	install -m 750 files/internals/lmd_session.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_session.sh
	install -m 750 files/internals/lmd_lifecycle.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_lifecycle.sh
	install -m 750 files/internals/lmd_scan.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_scan.sh
	install -m 750 files/internals/lmd_monitor.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_monitor.sh
	install -m 750 files/internals/lmd_update.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_update.sh
	install -m 750 files/internals/lmd_alert.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/lmd_alert.sh
	install -m 640 files/internals/compat.conf $(CURDIR)/debian/maldet/usr/lib/maldet/internals/compat.conf
	install -m 750 files/internals/tlog_lib.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/tlog_lib.sh
	install -m 750 files/internals/elog_lib.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/elog_lib.sh
	install -m 750 files/internals/alert_lib.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/alert_lib.sh
	install -m 750 files/internals/pkg_lib.sh $(CURDIR)/debian/maldet/usr/lib/maldet/internals/pkg_lib.sh
	install -m 755 files/internals/tlog.pkg $(CURDIR)/debian/maldet/usr/lib/maldet/internals/tlog
	for tpl in files/internals/alert/*.tpl; do \
	    install -m 640 "$$tpl" $(CURDIR)/debian/maldet/usr/lib/maldet/internals/alert/; \
	done
	install -m 640 pkg/symlink-manifest $(CURDIR)/debian/maldet/usr/lib/maldet/internals/.symlink-manifest
	install -m 640 files/cron/conf.maldet.cron $(CURDIR)/debian/maldet/usr/lib/maldet/cron/conf.maldet.cron
	install -m 640 files/cron/custom.cron $(CURDIR)/debian/maldet/usr/lib/maldet/cron/custom.cron
	install -m 640 files/conf.maldet $(CURDIR)/debian/maldet/etc/maldet/conf.maldet
	install -m 640 files/conf.maldet.hookscan.default $(CURDIR)/debian/maldet/etc/maldet/conf.maldet.hookscan.default
	install -m 640 files/ignore_paths $(CURDIR)/debian/maldet/etc/maldet/ignore_paths
	install -m 640 files/ignore_file_ext $(CURDIR)/debian/maldet/etc/maldet/ignore_file_ext
	install -m 640 files/ignore_sigs $(CURDIR)/debian/maldet/etc/maldet/ignore_sigs
	install -m 640 files/ignore_inotify $(CURDIR)/debian/maldet/etc/maldet/ignore_inotify
	install -m 640 files/monitor_paths $(CURDIR)/debian/maldet/etc/maldet/monitor_paths
	touch $(CURDIR)/debian/maldet/etc/maldet/monitor_paths.extra
	chmod 640 $(CURDIR)/debian/maldet/etc/maldet/monitor_paths.extra
	for cr in files/clean/*; do \
	    install -m 750 "$$cr" $(CURDIR)/debian/maldet/var/lib/maldet/clean/; \
	done
	mkdir -p $(CURDIR)/debian/maldet/lib/systemd/system
	install -m 644 files/service/maldet.service.pkg $(CURDIR)/debian/maldet/lib/systemd/system/maldet.service
	mkdir -p $(CURDIR)/debian/maldet/etc/default
	install -m 640 files/service/maldet.sysconfig.pkg $(CURDIR)/debian/maldet/etc/default/maldet
	mkdir -p $(CURDIR)/debian/maldet/etc/cron.daily
	install -m 755 cron.daily.pkg $(CURDIR)/debian/maldet/etc/cron.daily/maldet
	mkdir -p $(CURDIR)/debian/maldet/etc/cron.d
	install -m 644 cron.d.sigup.pkg $(CURDIR)/debian/maldet/etc/cron.d/maldet-sigup
	install -m 644 cron.d.pub.pkg $(CURDIR)/debian/maldet/etc/cron.d/maldet_pub
	mkdir -p $(CURDIR)/debian/maldet/etc/cron.weekly
	install -m 755 cron.watchdog.pkg $(CURDIR)/debian/maldet/etc/cron.weekly/maldet-watchdog
	install -m 644 files/maldet.1.pkg.gz $(CURDIR)/debian/maldet/usr/share/man/man1/maldet.1.gz
	install -m 644 README $(CURDIR)/debian/maldet/usr/share/doc/maldet/README
	install -m 644 CHANGELOG $(CURDIR)/debian/maldet/usr/share/doc/maldet/CHANGELOG
	install -m 644 COPYING.GPL $(CURDIR)/debian/maldet/usr/share/doc/maldet/COPYING.GPL

override_dh_auto_test:
	# Skip — tests require privileged Docker environment

override_dh_auto_clean:
	rm -f files/internals/internals.conf.pkg
	rm -f files/internals/tlog.pkg
	rm -f files/service/maldet.service.pkg
	rm -f files/service/maldet.sysconfig.pkg
	rm -f cron.daily.pkg cron.d.sigup.pkg cron.d.pub.pkg cron.watchdog.pkg
	rm -f files/maldet.1.pkg files/maldet.1.pkg.gz
