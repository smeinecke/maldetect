#!/bin/bash
# maldet postrm — generated by pkg_gen.sh from pkg_lib templates
#
# Post-remove scriptlet: cleans up symlink farm directory, state, and
# config on purge.
#
# Placeholders:
#   maldet          — package name
#   /usr/local/maldetect  — legacy install path
#   /usr/local/sbin/maldet    — legacy binary path (e.g., /usr/local/sbin/bfd)
#
#
set -e

case "$1" in
    remove)
        # Clean up the symlink farm directory (links are removed by dpkg,
        # but the directory itself and any runtime-created files remain)
        rm -rf /usr/local/maldetect 2>/dev/null || true
        rm -f /usr/local/sbin/maldet 2>/dev/null || true
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload 2>/dev/null || true
        fi
        ;;
    purge)
        # Clean up symlink farm
        rm -rf /usr/local/maldetect 2>/dev/null || true
        rm -f /usr/local/sbin/maldet 2>/dev/null || true
        # Remove config directory on purge
        rm -rf /etc/maldet 2>/dev/null || true
        # Remove state
        rm -rf /var/lib/maldet 2>/dev/null || true
        rm -rf /var/log/maldet 2>/dev/null || true
        for _cpath in /var/lib/clamav /usr/share/clamav /usr/local/share/clamav \
                      /usr/local/cpanel/3rdparty/share/clamav /var/clamav; do
            rm -f "$_cpath"/rfxn.{hdb,ndb,yara,hsb} "$_cpath"/lmd.user.* 2>/dev/null || true
        done
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload 2>/dev/null || true
        fi
        ;;
esac

#DEBHELPER#

exit 0
